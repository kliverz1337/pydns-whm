# PYDNS Scanner — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: .env contains secrets — NEVER commit it to git!

# GitHub Personal Access Token (for syncing/pushing results)
GITHUB_TOKEN=

# Debug mode (true/false)
DEBUG_MODE=false

# Custom API keys (if needed)
# API_KEY=